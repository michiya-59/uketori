# ==============================
# ウケトリ 環境変数テンプレート
# ==============================
# .env にコピーして値を設定してください
# cp .env.example .env

# --- AI (Claude API) ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- メール (SendGrid) ---
SENDGRID_API_KEY=
MAILER_FROM=noreply@uketori.local

# --- 国税庁適格番号API ---
NTA_APP_ID=

# --- JWT認証 ---
JWT_SECRET=dev-secret-key-change-in-production
JWT_EXPIRATION=900
JWT_REFRESH_EXPIRATION=604800

# --- ストレージ (S3互換 / Cloudflare R2) ---
# 開発環境ではMinIOの値がdocker-compose.ymlに設定済み
# 本番ではCloudflare R2の値を設定
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_ENDPOINT=http://minio:9000
R2_BUCKET=uketori-dev

# --- データベース ---
# 開発環境ではdocker-compose.ymlに設定済み
# DATABASE_URL=postgres://postgres:password@db:5432/uketori_development

# --- フロントエンド ---
NEXT_PUBLIC_API_URL=http://localhost:4100

# --- Stripe (Phase 3で使用) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_STANDARD_PRICE_ID=
STRIPE_PROFESSIONAL_PRICE_ID=
